# Azure OpenAI — copy this file to .env and populate with your values.
# .env is git-ignored; never commit the populated file.

# Your Azure OpenAI resource endpoint (include the trailing slash)
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# API key from the Azure portal (Keys and Endpoint blade)
AZURE_OPENAI_KEY=your-api-key-here

# API version — 2024-08-01-preview or later is required for structured outputs
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# The deployment name you created in Azure OpenAI Studio (not the model name)
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
